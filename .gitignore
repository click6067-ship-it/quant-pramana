# ── secrets (절대 커밋 금지) ──
.ndl_key
**/.ndl_key
*.key
.env
**/.env
*secret*
*password*

# ── 라이선스 bulk 데이터만 제외 (Sharadar raw 1.2GB·동결 스냅샷). 파생 결과/대시보드는 추적 ──
outputs/raw/
**/outputs/raw/
outputs/snapshots/
**/outputs/snapshots/
outputs/*.log
**/outputs/*.log
*.csv.gz

# ── 환경/캐시 ──
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store

# ── 대용량 데이터 확장자(안전망) ──
# 코드/문서(.py·.md·requirements·registry csv)는 추적, raw 데이터 csv는 outputs/에 있어 위에서 제외됨

# Alpha Lab intraday 적재(매일 커짐·yfinance 재생성 가능·코드만 추적)
outputs/alpha_lab/
**/outputs/alpha_lab/

# A1 라이브 런타임(prices·state·nav_log·positions·cron.log — 매일 갱신·재생성 가능. 대시보드 outputs/a1_live_dashboard.html은 직속이라 추적됨)
outputs/a1_live/
**/outputs/a1_live/

# A2 라이브 런타임(동일 · 대시보드 outputs/a2_live_dashboard.html은 직속 추적)
outputs/a2_live/
**/outputs/a2_live/

# ── data/paper artifacts (Sharadar·Yahoo 파생 / paper NAV·ledger — license/ToS surface, 로컬에서 재생성) ──
phase1a/outputs/**/*.csv
phase1a/outputs/**/*.json

# auto-generated B0 run log (reproduce.sh appends per run)
phase1a/registry/b0_runs.csv

# dashboard build artifacts (submission copy lives in docs/ for Pages)
phase1a/outputs/**/*.html
phase1a/outputs/**/*.png
